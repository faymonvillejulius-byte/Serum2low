# Environment Variables Template

# Cloudflare Configuration
# Get your KV namespace ID from: https://dash.cloudflare.com/ → Workers → KV
# Replace with your actual ID (do NOT commit this file)
CLOUDFLARE_KV_NAMESPACE_ID=YOUR_KV_NAMESPACE_ID_HERE

# API Keys (Optional - for AI-powered descriptions)
# Get from: https://console.groq.com/
GROQ_KEY=your_groq_api_key_here

# Alternative AI provider
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Security
# Use a strong random string for cache invalidation endpoint
REFRESH_SECRET=your_super_secret_refresh_token_here

# Cloudflare API (for CI/CD)
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
